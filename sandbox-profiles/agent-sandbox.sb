(version 1)

;; ---------------------------------------------------------------------------
;; Agent Sandbox Policy — Liam's workstation
;; Deny-by-default sandbox for Claude Code and Codex CLI agents.
;;
;; Structure mirrors Agent Safehouse (github.com/eugene1g/agent-safehouse):
;;   00-base, 10-system-runtime, 20-network, 30-toolchains (node, dotnet),
;;   40-shared (agent-common), 50-integrations-core (git, scm-clis, launch-services),
;;   55-integrations-optional (shell-init, keychain, ssh),
;;   60-agents (claude-code, codex), dynamic workdir grants.
;;
;; Debug sandbox denials:
;;   /usr/bin/log stream --style compact --predicate 'eventMessage CONTAINS "Sandbox:" AND eventMessage CONTAINS "deny("'
;; ---------------------------------------------------------------------------


;; ===== 00-base ==============================================================
;; Sourced from: Agent Safehouse profiles/00-base.sb

(define HOME_DIR "/Users/liam")

(define (home-subpath rel) (subpath (string-append HOME_DIR rel)))
(define (home-literal rel) (literal (string-append HOME_DIR rel)))
(define (home-prefix rel) (prefix (string-append HOME_DIR rel)))

(deny default)


;; ===== 10-system-runtime ====================================================
;; Sourced from: Agent Safehouse profiles/10-system-runtime.sb
;; Process execution, tmp/dev, system binaries, baseline mach services.

(allow file-read*
    (subpath "/usr")
    (subpath "/bin")
    (subpath "/sbin")
    (subpath "/opt")                                                  ;; Homebrew root at /opt/homebrew.
    (subpath "/System/Library")
    (subpath "/System/Volumes/Preboot")
    (subpath "/Library/Apple")
    (subpath "/Library/Frameworks")
    (subpath "/Library/Fonts")
    (subpath "/Library/Filesystems/NetFSPlugins")
    (subpath "/Library/Preferences/Logging")
    (literal "/Library/Preferences/.GlobalPreferences.plist")
    (literal "/Library/Preferences/com.apple.networkd.plist")
    (literal "/dev")
)

(allow file-read-metadata
    (subpath "/System")
    (subpath "/private/var/run")
)

;; /etc and /var symlinks into /private/*.
(allow file-read*
    (literal "/private")
    (literal "/private/var")
    (subpath "/private/var/db/timezone")
    (literal "/private/var/select/sh")
    (literal "/private/var/select/developer_dir")
    (literal "/var/select/developer_dir")
    (literal "/private/var/db/xcode_select_link")
    (literal "/var/db/xcode_select_link")
    (literal "/private/etc/hosts")
    (literal "/private/etc/resolv.conf")
    (literal "/private/etc/services")
    (literal "/private/etc/protocols")
    (literal "/private/etc/shells")
    (subpath "/private/etc/ssl")
    (literal "/private/etc/localtime")
    (literal "/etc")
    (literal "/var")
)

;; XDG/home probe metadata used by tooling at startup.
(allow file-read-metadata
    (literal "/home")
    (literal "/private/etc")
    (subpath "/dev")
    (home-literal "/.config")
    (home-literal "/.cache")
    (home-literal "/.local")
    (home-literal "/.local/share")
)

;; User preference reads.
(allow file-read*
    (home-prefix "/Library/Preferences/.GlobalPreferences")
    (home-prefix "/Library/Preferences/com.apple.GlobalPreferences")
    (home-subpath "/Library/Preferences/ByHost")
    (home-literal "/.CFUserTextEncoding")
    (home-literal "/.config")
    (home-literal "/.cache")
    (home-literal "/.local/bin")
)

;; Process primitives — agents chain many subprocesses.
(allow process-exec)
(allow process-fork)
(allow sysctl-read)
(allow process-info* (target same-sandbox))
(allow signal (target same-sandbox))
(allow mach-priv-task-port (target same-sandbox))
(allow pseudo-tty)

;; Temporary files and sockets.
(allow file-read* file-write*
    (subpath "/tmp")
    (subpath "/private/tmp")
    (subpath "/var/folders")
    (subpath "/private/var/folders")
)

;; Defense-in-depth: deny launchd listener sockets by default.
(deny file-read* file-write*
    (regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$")
    (regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$")
)

;; Device nodes for shell I/O and PTYs.
(allow file-read* file-write*
    (subpath "/dev/fd")
    (literal "/dev/stdout")
    (literal "/dev/stderr")
    (literal "/dev/null")
    (literal "/dev/tty")
    (literal "/dev/ptmx")
    (literal "/dev/dtracehelper")
    (regex #"^/dev/tty")
    (regex #"^/dev/ttys")
    (regex #"^/dev/pty")
)

(allow file-read*
    (literal "/dev/zero")
    (literal "/dev/autofs_nowait")
    (literal "/dev/dtracehelper")
    (literal "/dev/urandom")
    (literal "/dev/random")
)

(allow file-ioctl
    (literal "/dev/dtracehelper")
    (literal "/dev/tty")
    (literal "/dev/ptmx")
    (regex #"^/dev/tty")
    (regex #"^/dev/ttys")
    (regex #"^/dev/pty")
)

;; Baseline mach services.
(allow mach-lookup
    (global-name "com.apple.system.notification_center")
    (global-name "com.apple.system.opendirectoryd.libinfo")
    (global-name "com.apple.logd")
    (global-name "com.apple.FSEvents")
    (global-name "com.apple.SystemConfiguration.configd")
    (global-name "com.apple.SystemConfiguration.DNSConfiguration")
    (global-name "com.apple.trustd.agent")
    (global-name "com.apple.diagnosticd")
    (global-name "com.apple.analyticsd")
    (global-name "com.apple.dnssd.service")
    (global-name "com.apple.CoreServices.coreservicesd")
    (global-name "com.apple.DiskArbitration.diskarbitrationd")
    (global-name "com.apple.analyticsd.messagetracer")
    (global-name "com.apple.system.logger")
    (global-name "com.apple.coreservices.launchservicesd")
)

(allow system-socket)

(allow ipc-posix-shm-read-data
    (ipc-posix-name "apple.shm.notification_center")
)

;; HOME ancestor metadata for home-scoped toolchain discovery.
(allow file-read-metadata
    (literal "/")
    (literal "/Users")
    (literal "/Users/liam")
)


;; ===== 20-network ===========================================================
;; Sourced from: Agent Safehouse profiles/20-network.sb
;; Fully open — exfiltration prevention is not a goal of this sandbox.

(allow network*)


;; ===== 30-toolchains/node ===================================================
;; Sourced from: Agent Safehouse profiles/30-toolchains/node.sb
;; Node.js via nvm, npm caches. Yarn/pnpm included for completeness.

(allow file-read* file-write*
    ;; nvm — the active version manager.
    (home-subpath "/.nvm")

    ;; npm
    (home-subpath "/.npm")
    (home-subpath "/.config/npm")
    (home-subpath "/.cache/npm")
    (home-subpath "/.cache/node")
    (home-subpath "/.cache/prisma")
    (home-subpath "/Library/Caches/npm")
    (home-literal "/.npmrc")

    ;; configstore (npm ecosystem config persistence)
    (home-subpath "/.config/configstore")

    ;; node-gyp
    (home-subpath "/.node-gyp")
    (home-subpath "/.cache/node-gyp")

    ;; yarn (classic + modern) — project uses npm but yarn may appear transitively.
    (home-subpath "/.yarn")
    (home-literal "/.yarnrc")
    (home-literal "/.yarnrc.yml")
    (home-subpath "/.config/yarn")
    (home-subpath "/.cache/yarn")
    (home-subpath "/Library/Caches/Yarn")

    ;; corepack
    (home-subpath "/.cache/node/corepack")
    (home-subpath "/Library/Caches/node/corepack")

    ;; Playwright (E2E tests)
    (home-subpath "/Library/Caches/ms-playwright")

    ;; TypeScript cache
    (home-subpath "/Library/Caches/typescript")

    ;; Angular CLI cache
    (home-subpath "/.angular")

    ;; Angular CLI global config — ng hardcodes path.join(os.homedir(), '.angular-config.json')
    ;; and crashes with EPERM if it can't open it. Required for ng build/serve/test.
    (home-literal "/.angular-config.json")
)


;; ===== 30-toolchains/dotnet =================================================
;; Custom — no Safehouse equivalent. Modeled on node.sb least-privilege pattern.

(allow file-read* file-write*
    ;; .NET SDK and runtime install root.
    ;; /usr/local/share/dotnet is already covered by (subpath "/usr") read grant;
    ;; this explicit entry covers the write path for SDK telemetry/first-run state.
    (subpath "/usr/local/share/dotnet")

    ;; Per-user .NET CLI state, sentinel files, tool path cache.
    (home-subpath "/.dotnet")

    ;; NuGet package cache and plugin store.
    (home-subpath "/.nuget")

    ;; NuGet configuration.
    (home-subpath "/.config/NuGet")

    ;; dotnet global tools (dotnet-ef, csharpier, etc.).
    (home-subpath "/.dotnet/tools")

    ;; OmniSharp (LSP for C# in editors).
    (home-subpath "/.omnisharp")

    ;; Temporary build/restore artifacts written by MSBuild.
    (home-subpath "/.local/share/NuGet")
)


;; ===== 30-toolchains/apple-toolchain-core ===================================
;; Sourced from: Agent Safehouse profiles/30-toolchains/apple-toolchain-core.sb
;; Curated CLT binaries needed by git and native compilation (node-gyp, dotnet native).

(allow file-read*
    (literal "/Library")
    (literal "/Library/Developer")
    (literal "/Library/Developer/CommandLineTools")
    (literal "/Library/Developer/CommandLineTools/usr")
    (literal "/Library/Developer/CommandLineTools/usr/bin")
    (literal "/Library/Developer/CommandLineTools/usr/include")
    (literal "/Library/Developer/CommandLineTools/usr/lib")
    (literal "/Library/Developer/CommandLineTools/usr/libexec")
    (literal "/Library/Developer/CommandLineTools/usr/libexec/git-core")
    (literal "/Library/Developer/CommandLineTools/usr/share")
    (literal "/Library/Developer/CommandLineTools/SDKs")
    (literal "/Library/Developer/CommandLineTools/usr/bin/git")
    (literal "/Library/Developer/CommandLineTools/usr/bin/make")
    (literal "/Library/Developer/CommandLineTools/usr/bin/clang")
    (literal "/Library/Developer/CommandLineTools/usr/bin/cc")
    (literal "/Library/Developer/CommandLineTools/usr/bin/c++")
    (literal "/Library/Developer/CommandLineTools/usr/bin/gcc")
    (literal "/Library/Developer/CommandLineTools/usr/bin/g++")
    (literal "/Library/Developer/CommandLineTools/usr/bin/ar")
    (literal "/Library/Developer/CommandLineTools/usr/bin/ranlib")
    (literal "/Library/Developer/CommandLineTools/usr/bin/ld")
    (literal "/Library/Developer/CommandLineTools/usr/bin/strip")
    (subpath "/Library/Developer/CommandLineTools/usr/libexec/git-core")
    (subpath "/Library/Developer/CommandLineTools/usr/include")
    (subpath "/Library/Developer/CommandLineTools/usr/lib")
    (subpath "/Library/Developer/CommandLineTools/usr/share")
    (subpath "/Library/Developer/CommandLineTools/SDKs")
)


;; ===== 40-shared/agent-common ===============================================
;; Sourced from: Agent Safehouse profiles/40-shared/agent-common.sb

(allow file-read* file-write*
    (home-subpath "/.skills")
    (home-subpath "/.agents")
    (home-literal "/AGENTS.md")
)

(allow file-read*
    (home-subpath "/.claude/agents")
    (home-subpath "/.claude/skills")
    (home-literal "/CLAUDE.md")
)


;; ===== 50-integrations-core/git =============================================
;; Sourced from: Agent Safehouse profiles/50-integrations-core/git.sb

(allow file-read*
    (home-prefix "/.gitconfig")                                       ;; Symlink to ~/dotfiles/.gitconfig.
    (home-prefix "/.gitignore")
    (home-subpath "/.config/git")
    (home-literal "/.gitattributes")
    (home-literal "/.ssh")
    (home-literal "/.ssh/config")
    (home-literal "/.ssh/known_hosts")
)


;; ===== 50-integrations-core/scm-clis ========================================
;; Sourced from: Agent Safehouse profiles/50-integrations-core/scm-clis.sb
;; GitHub CLI (gh) for PR workflows.

(allow file-read* file-write*
    (home-subpath "/.config/gh")
    (home-subpath "/.cache/gh")
    (home-subpath "/.local/share/gh")
    (home-subpath "/.local/state/gh")
)


;; ===== 50-integrations-core/launch-services =================================
;; Sourced from: Agent Safehouse profiles/50-integrations-core/launch-services.sb
;; Enables `open` command for browser OAuth flows (gh auth, claude login, etc.).

(allow mach-lookup
    (global-name "com.apple.lsd.mapdb")
    (global-name "com.apple.lsd.modifydb")
    (global-name "com.apple.coreservices.quarantine-resolver")
)

(allow file-issue-extension
    (extension-class "com.apple.app-sandbox.read")
    (extension-class "com.apple.app-sandbox.read-write")
)

(allow lsopen)

;; Allow reading the default browser app bundle (Google Chrome) so `open` can resolve it.
(allow file-read-metadata
    (literal "/Applications")
    (subpath "/Applications/Google Chrome.app")
)


;; ===== 55-integrations-optional/shell-init ==================================
;; Sourced from: Agent Safehouse profiles/55-integrations-optional/shell-init.sb
;; Shell startup files for PATH/env bootstrap in spawned shells.

(allow file-read*
    (literal "/private/etc/profile")
    (literal "/private/etc/paths")
    (subpath "/private/etc/paths.d")
    (literal "/private/etc/zprofile")
    (literal "/private/etc/zshrc")
    (home-literal "/.zshenv")
    (home-literal "/.cargo/env")                                      ;; Sourced by .zshenv; blocked read pollutes all command output.
    (home-literal "/.zprofile")
    (home-literal "/.zshrc")                                          ;; Symlink to ~/dotfiles/.zshrc.
    (home-literal "/.zcompdump")
    (home-prefix "/.zcompdump")
    (home-literal "/.bashrc")
    (literal "/private/etc/bashrc")
    (literal "/Applications")
    (literal "/System/Volumes/Data/Applications")
)


;; ===== 55-integrations-optional/keychain ====================================
;; Sourced from: Agent Safehouse profiles/55-integrations-optional/keychain.sb
;; Required by claude-code and codex for credential storage.

(allow file-read* file-write*
    (home-subpath "/Library/Keychains")
    (home-literal "/Library/Preferences/com.apple.security.plist")
)

(allow file-read*
    (literal "/Library/Preferences/com.apple.security.plist")
    (literal "/Library/Keychains/System.keychain")
    (subpath "/private/var/db/mds")
)

(allow file-read-metadata
    (home-literal "/Library")
    (home-literal "/Library/Keychains")
    (literal "/Library/Keychains")
)

(allow mach-lookup
    (global-name "com.apple.SecurityServer")
    (global-name "com.apple.security.agent")
    (global-name "com.apple.securityd.xpc")
    (global-name "com.apple.security.authhost")
    (global-name "com.apple.secd")
    (global-name "com.apple.trustd")
)

(allow ipc-posix-shm-read-data ipc-posix-shm-write-create ipc-posix-shm-write-data
    (ipc-posix-name "com.apple.AppleDatabaseChanged")
)


;; ===== 55-integrations-optional/ssh =========================================
;; Sourced from: Agent Safehouse profiles/55-integrations-optional/ssh.sb
;; SSH agent socket access for git-over-ssh; private keys denied.

;; Defense-in-depth: block private key reads.
(deny file-read* file-write*
    (home-subpath "/.ssh")
)

(allow file-read-metadata
    (home-literal "/.ssh")
)

;; Allow non-sensitive SSH metadata.
(allow file-read*
    (home-literal "/.ssh/known_hosts")
    (home-literal "/.ssh/config")
    (home-subpath "/.ssh/config.d")
    (home-literal "/.ssh/allowed_signers")
    (literal "/private/etc/ssh/ssh_config")
    (subpath "/private/etc/ssh/ssh_config.d")
    (literal "/private/etc/ssh/crypto.conf")
    (subpath "/private/etc/ssh/crypto")
)

(allow file-write*
    (home-literal "/.ssh/known_hosts")
    (home-literal "/.ssh/known_hosts.old")
)

(allow file-read-metadata
    (home-literal "/.ssh/agent")
)

;; SSH agent socket access via launchd.
(allow file-read* file-write*
    (regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$")
    (regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$")
    (home-subpath "/.ssh/agent")
)

(allow network-outbound
    (remote unix-socket (path-regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$"))
    (remote unix-socket (path-regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$"))
    (remote unix-socket (path-regex #"^/Users/liam/\\.ssh/agent(/.*)?$"))
)


;; ===== 60-agents/claude-code ================================================
;; Sourced from: Agent Safehouse profiles/60-agents/claude-code.sb

(allow file-read* file-write*
    (home-prefix "/.local/bin/claude")
    (home-subpath "/.cache/claude")
    (home-subpath "/.claude")
    (home-prefix "/.claude.json")
    (home-literal "/.claude.lock")
    (home-subpath "/.config/claude")
    (home-subpath "/.local/state/claude")
    (home-subpath "/.local/share/claude")
    (home-literal "/.mcp.json")
)

(allow file-read*
    (home-prefix "/.claude.json.")
    (home-literal "/Library/Application Support/Claude/claude_desktop_config.json")
    (subpath "/Library/Application Support/ClaudeCode/.claude")
    (literal "/Library/Application Support/ClaudeCode/managed-settings.json")
    (literal "/Library/Application Support/ClaudeCode/managed-mcp.json")
    (literal "/Library/Application Support/ClaudeCode/CLAUDE.md")
)


;; ===== Symlink resolution ===================================================
;; ~/.zshrc and ~/.gitconfig are symlinks into ~/dotfiles/.
;; Following Safehouse emit_resolved_home_path_rules pattern, grant read on
;; the real target path so the symlink actually resolves.

;; Ancestor literals for ~/dotfiles (read-only symlink target).
(allow file-read*
    (literal "/")
    (literal "/Users")
    (literal "/Users/liam")
    (literal "/Users/liam/dotfiles")
)

(allow file-read*
    (literal "/Users/liam/dotfiles/.zshrc")
    (literal "/Users/liam/dotfiles/.gitconfig")
)


;; ===== Starship prompt config ===============================================
;; starship reads its config on every shell prompt render.

(allow file-read*
    (home-subpath "/.config/starship")
    (home-literal "/.config/starship.toml")
)

(allow file-read* file-write*
    (home-subpath "/.cache/starship")
)


;; ===== fzf shell integration ================================================

(allow file-read*
    (home-literal "/.fzf.zsh")
    (home-subpath "/.fzf")
)


;; ===== direnv ===============================================================
;; direnv hooks into the shell and reads .envrc files from the workdir.

(allow file-read*
    (home-subpath "/.config/direnv")
)

(allow file-read* file-write*
    (home-subpath "/.local/share/direnv")
)


;; ===== Workdir: ~/Fulcrum (read/write) ======================================
;; Ancestor directory literals following Safehouse emit_path_ancestor_literals().
;; Uses literal (not subpath) on ancestors — grants readdir on the directory
;; entry itself without recursive read into siblings.

(allow file-read*
    (literal "/")
    (literal "/Users")
    (literal "/Users/liam")
    (literal "/Users/liam/Fulcrum")
)

(allow file-read* file-write*
    (subpath "/Users/liam/Fulcrum")
)
